# App
PORT=3001
HOST_PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=example
JWT_EXPIRES_IN=1h

# Postgres
# - Local dev (DB in Docker, API on host): use localhost
# - Full docker-compose (api container): compose overrides to DB_HOST=db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kku_library
DB_USER=kku
DB_PASSWORD=kku_password
